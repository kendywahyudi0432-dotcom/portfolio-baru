<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Portfolio Kendi Wahyudi - Content Creator & Computer Systems Student at Universitas Pamulang (UNPAM). Explore projects in C++, Python, and Data Analysis.">
    <meta name="keywords" content="Kendi Wahyudi, Computer Systems, UNPAM, Content Creator, Portfolio, C++, Python, Excel, Data Analysis, Universitas Pamulang">
    <meta name="author" content="Kendi Wahyudi">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="Kendi Wahyudi - Portfolio">
    <meta property="og:description" content="Content Creator & Computer Systems Student. Explore my projects and experience.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://kendiwahyudi.vercel.app">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Kendi Wahyudi - Portfolio">
    <meta name="twitter:description" content="Content Creator & Computer Systems Student at UNPAM">
    <title><%= typeof title !== 'undefined' ? title : 'Kendi Wahyudi - Portfolio' %></title>
    <link rel="stylesheet" href="/css/output.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        * { font-family: 'Inter', sans-serif; }
        html { scroll-behavior: smooth; }
        :root { --accent: #0066FF; }

        /* ====== DARK MODE (default) ====== */
        .dark body {
            background-color: #0a0e27 !important;
            color: #e2e8f0 !important;
        }
        .dark .bg-nav { background: rgba(10, 14, 39, 0.9); border-color: #1e2748; }
        .dark .text-primary { color: #fff; }
        .dark .text-nav { color: #cbd5e1; }
        .dark .text-nav-hover:hover { color: var(--accent) !important; }
        .dark .card-base { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); }
        .dark .section-bg { background: rgba(0, 102, 255, 0.03); }
        .dark .text-muted { color: #94a3b8; }
        .dark .text-white-default { color: #fff; }
        .dark .mobile-bg { background: rgba(10, 14, 39, 0.98); }
        .dark .social-bg { background: rgba(255,255,255,0.05); color: #94a3b8; }
        .dark .btn-toggle { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); }
        .dark .hero-bg { background: #0a0e27; }
        .dark .section-alt-bg { background: rgba(0, 102, 255, 0.03); }
        .dark .footer-bg { background: #070a1f; border-color: #1e2748; }

        /* ====== LIGHT MODE ====== */
        .light body {
            background-color: #ffffff !important;
            color: #0f172a !important;
        }
        .light .bg-nav { background: rgba(255,255,255,0.9); border-color: #e2e8f0; }
        .light .text-primary { color: #0f172a; }
        .light .text-nav { color: #334155; }
        .light .text-nav-hover:hover { color: var(--accent) !important; }
        .light .card-base { background: #f8fafc; border: 1px solid #e2e8f0; }
        .light .section-bg { background: #f1f5f9; }
        .light .text-muted { color: #475569; }
        .light .text-white-default { color: #0f172a; }
        .light .mobile-bg { background: rgba(255, 255, 255, 0.98); }
        .light .social-bg { background: #f1f5f9; color: #475569; }
        .light .btn-toggle { background: rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.15); }
        .light .hero-bg { background: #ffffff; }
        .light .section-alt-bg { background: #f8fafc; }
        .light .footer-bg { background: #f1f5f9; border-color: #e2e8f0; }

        /* ====== Shared ====== */
        .accent-text { color: var(--accent); }
        .accent-bg { background-color: var(--accent); }
        .accent-border { border-color: var(--accent); }
        .accent-glow { box-shadow: 0 0 20px rgba(0, 102, 255, 0.3); }
        .accent-hover:hover { background-color: var(--accent) !important; border-color: var(--accent) !important; color: #fff !important; }
        .accent-shadow { text-shadow: 0 0 20px rgba(0, 102, 255, 0.5), 0 0 40px rgba(0, 102, 255, 0.3); }
        .accent-glow-text { text-shadow: 0 0 12px rgba(0, 102, 255, 0.6), 0 0 24px rgba(0, 102, 255, 0.3); }
        .neon-glow { box-shadow: 0 0 10px rgba(0, 102, 255, 0.5), 0 0 20px rgba(0, 102, 255, 0.2); }

        .nav-link { position: relative; transition: color 0.3s; }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--accent);
            transition: width 0.3s;
        }
        .nav-link:hover::after { width: 100%; }
        .nav-link:hover { color: var(--accent) !important; }

        .glow-card { transition: all 0.3s ease; }
        .glow-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 40px rgba(0, 102, 255, 0.15);
            border-color: var(--accent) !important;
        }

        .btn-primary {
            background: var(--accent);
            color: #fff;
            padding: 12px 32px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-block;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 102, 255, 0.35);
        }
        .btn-outline {
            background: transparent;
            color: var(--accent);
            border: 2px solid var(--accent);
            padding: 10px 30px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-block;
        }
        .btn-outline:hover {
            background: var(--accent);
            color: #fff;
            transform: translateY(-2px);
        }
        .section-title {
            font-size: 2rem;
            font-weight: 700;
            position: relative;
            display: inline-block;
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 60px;
            height: 3px;
            background: var(--accent);
            border-radius: 2px;
        }
        .profile-img { border: 3px solid var(--accent); }
        .theme-toggle {
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1.2rem;
        }
        .theme-toggle:hover { background: var(--accent) !important; border-color: var(--accent) !important; }
        .mobile-nav { transition: all 0.3s ease; }
        .experience-dot {
            width: 16px;
            height: 16px;
            background: var(--accent);
            border-radius: 50%;
            position: absolute;
            left: -8px;
            top: 5px;
            z-index: 2;
            box-shadow: 0 0 10px rgba(0, 102, 255, 0.4);
        }
        .timeline-line {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--accent), rgba(0,102,255,0.1));
        }
        .dark .timeline-line { background: linear-gradient(to bottom, var(--accent), rgba(0,102,255,0.05)); }
        .social-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            font-size: 1.3rem;
        }
        .social-icon:hover { background: var(--accent) !important; color: #fff !important; transform: translateY(-3px); }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes fade-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="bg-nav fixed top-0 left-0 right-0 z-50 backdrop-blur-xl border-b">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="text-primary text-xl font-bold">
                    Kendi<span class="accent-text">.</span>
                </a>

                <!-- Desktop Nav -->
                <div class="hidden md:flex items-center space-x-8">
                    <a href="#home" class="nav-link text-nav text-sm font-medium">Home</a>
                    <a href="#experience" class="nav-link text-nav text-sm font-medium">Experience</a>
                    <a href="#portfolio" class="nav-link text-nav text-sm font-medium">Portfolio</a>
                    <a href="#contact" class="nav-link text-nav text-sm font-medium">Contact</a>
                    <button id="themeToggle" class="theme-toggle btn-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
                        <span id="themeIcon">☀️</span>
                    </button>
                </div>

                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center space-x-2">
                    <button id="themeToggleMobile" class="theme-toggle btn-toggle" onclick="toggleTheme()" aria-label="Toggle theme" style="width:36px;height:36px;font-size:1rem;">
                        <span id="themeIconMobile">☀️</span>
                    </button>
                    <button id="menuBtn" class="text-primary focus:outline-none" onclick="toggleMenu()">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path id="menuIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobileMenu" class="mobile-nav mobile-bg hidden md:hidden border-t border-gray-200/20">
            <div class="px-4 py-4 space-y-3">
                <a href="#home" onclick="toggleMenu()" class="text-nav block px-3 py-2 rounded-lg text-sm font-medium">Home</a>
                <a href="#experience" onclick="toggleMenu()" class="text-nav block px-3 py-2 rounded-lg text-sm font-medium">Experience</a>
                <a href="#portfolio" onclick="toggleMenu()" class="text-nav block px-3 py-2 rounded-lg text-sm font-medium">Portfolio</a>
                <a href="#contact" onclick="toggleMenu()" class="text-nav block px-3 py-2 rounded-lg text-sm font-medium">Contact</a>
            </div>
        </div>
    </nav>

    <!-- Spacer for fixed nav -->
    <div class="h-16"></div>