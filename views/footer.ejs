<script>
// Theme toggle function - toggles 'dark'/'light' class on <html> element
function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    
    if (isDark) {
        html.classList.remove('dark');
        html.classList.add('light');
        localStorage.setItem('theme', 'light');
    } else {
        html.classList.remove('light');
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
    }
    
    // Update theme icons
    const currentTheme = html.classList.contains('dark') ? 'dark' : 'light';
    document.querySelectorAll('[id^="themeIcon"]').forEach(el => {
        el.textContent = currentTheme === 'dark' ? '☀️' : '🌙';
    });
}

// Mobile menu toggle
function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    if (menu) {
        menu.classList.toggle('hidden');
    }
}

// On page load, restore saved theme
document.addEventListener('DOMContentLoaded', function() {
    const savedTheme = localStorage.getItem('theme');
    const html = document.documentElement;
    
    // Apply saved theme if it exists and differs from default
    if (savedTheme === 'light') {
        html.classList.remove('dark');
        html.classList.add('light');
    } else if (!savedTheme || savedTheme === 'dark') {
        html.classList.remove('light');
        html.classList.add('dark');
    }
    
    // Update theme icons to match current
    const currentTheme = html.classList.contains('dark') ? 'dark' : 'light';
    document.querySelectorAll('[id^="themeIcon"]').forEach(el => {
        el.textContent = currentTheme === 'dark' ? '☀️' : '🌙';
    });
    
    // Close mobile menu on link click
    document.querySelectorAll('#mobileMenu a').forEach(link => {
        link.addEventListener('click', function() {
            document.getElementById('mobileMenu')?.classList.add('hidden');
        });
    });
});
</script>
</body>
</html>